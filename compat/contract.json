{
  "schemaVersion": "cfw.compatibility-contract/v2",
  "name": "chocolatey-for-wine",
  "mode": "integrated-container-runtime",
  "requires": {
    "wine.prefix": {
      "architecture": "win64",
      "freshPrefix": true
    },
    "container.tools": [
      "python3",
      "7z",
      "winepath",
      "timeout"
    ]
  },
  "provides": {
    "package-manager": "chocolatey-2.6.0",
    "package-execution-host": "chocolatey-in-process-powershell",
    "dotnet-runtime": "cfw-dotnet48",
    "wine.compatibility-pack": "chocolatey-for-wine",
    "container-runtime": "cfw-integrated-chocolatey-runtime"
  },
  "optional": {
    "interactive-windows-powershell": {
      "provider": "synchro/powershell-wrapper-for-wine",
      "version": "v4.2.0",
      "requiredForPackageInstallation": false
    }
  },
  "contributes": {
    "powershell.profile-fragments": [
      "profile.d/20-chocolatey.ps1",
      "profile.d/30-cfw-winetricks.ps1",
      "profile.d/40-cfw-command-adapters.ps1"
    ]
  },
  "tools": {
    "nativeChocolateyFinalizer": {
      "source": "container-finalizer.c",
      "input": "%ProgramData%\\tools\\chocolateyInstall",
      "output": "%ProgramData%\\chocolatey"
    },
    "containerRuntimeFinalizer": {
      "source": "container-runtime.sh",
      "phase": "after-native-chocolatey-finalizer",
      "requiredEnvironment": [
        "WINEPREFIX",
        "CFW_PAYLOAD_CACHE_POSIX"
      ],
      "evidence": "cfw.container-runtime/v1"
    }
  },
  "ownership": {
    "dotnetAndClrCompatibility": "cfw",
    "chocolateyBootstrap": "cfw",
    "packageExecutionHost": "cfw",
    "wineCompatibilityFragments": "cfw",
    "interactiveWindowsPowerShell": "optional-external-provider",
    "recipeOrchestration": "consumer"
  },
  "constraints": {
    "consumerMustNotReconstructWmfOrGac": true,
    "consumerMustNotOwnCfwClrPayloads": true,
    "consumerMustVerifyRuntimeEvidence": true,
    "overwriteConsumerInteractiveProfile": false,
    "desktopInstallerMayRetainLegacyBehavior": true
  }
}
