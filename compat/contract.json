{
  "schemaVersion": "cfw.compatibility-contract/v3",
  "name": "chocolatey-for-wine",
  "mode": "prepared-prefix-runtime",
  "build": {
    "script": "build-runtime.sh",
    "inputs": "runtime-inputs.json",
    "wineCandidates": [
      "11.0"
    ],
    "freshWin64Prefix": true,
    "requiredProofs": [
      "wineIdentity",
      "installer",
      "prePwshPolicy",
      "pathConversions",
      "pwsh",
      "preparedFinalizer",
      "featurePolicy",
      "chocolatey",
      "synchroX64",
      "synchroX86",
      "chocolateyLifecycle"
    ]
  },
  "artifact": {
    "kind": "prepared-wine-prefix",
    "archive": "cfw-runtime-prefix.tar.gz",
    "evidence": "runtime.json",
    "manifest": "cfw-runtime-manifest.json",
    "seedSemantics": "replace-fresh-prefix",
    "mustPrecedeApplicationModules": true,
    "runtimeCompatibility": "declared-in-evidence",
    "interfaces": {
      "chocolatey": {
        "windowsPath": "C:\\ProgramData\\chocolatey\\bin\\choco.exe",
        "prefixRelativePath": "drive_c/ProgramData/chocolatey/bin/choco.exe"
      },
      "environment": {
        "WINEDLLOVERRIDES": ""
      }
    }
  },
  "provides": {
    "package-manager": "chocolatey-2.6.0",
    "package-execution-host": "external-windows-powershell",
    "windows-powershell-shim": "synchro-v4.2.0",
    "dotnet-runtime": "cfw-dotnet48",
    "wine.compatibility-pack": "chocolatey-for-wine",
    "prefix-foundation": "cfw-chocolatey-runtime"
  },
  "contributes": {
    "powershell.profile-fragments": [
      "profile.d/10-runtime-contract.ps1",
      "profile.d/20-chocolatey.ps1",
      "profile.d/30-cfw-winetricks.ps1",
      "profile.d/40-cfw-command-adapters.ps1"
    ]
  },
  "ownership": {
    "dotnetAndClrCompatibility": "cfw",
    "powershellRuntime": "cfw-runtime-artifact",
    "windowsPowerShellShim": "cfw-runtime-artifact",
    "profileLoader": "cfw-runtime-artifact",
    "chocolateyBootstrap": "cfw",
    "packageExecutionHost": "cfw-runtime-artifact",
    "wineCompatibilityFragments": "cfw",
    "artifactAcquisitionAndVerification": "consumer",
    "recipeOrchestration": "consumer"
  },
  "constraints": {
    "consumerMustNotReconstructWmfOrGac": true,
    "consumerMustNotInstallCfwClrPayloads": true,
    "consumerMustNotInstallSynchroForChocolatey": true,
    "consumerMustSeedArtifactBeforeOtherModules": true,
    "consumerMustVerifyArchiveDigest": true,
    "consumerMustVerifyRuntimeEvidence": true,
    "consumerMustVerifyRuntimeManifest": true,
    "consumerMustNotReplaceCfwProfileLoader": true,
    "chocolateyInProcessPowerShellHost": false,
    "desktopInstallerMayRetainLegacyBehavior": true
  },
  "rejected": {
    "chocolatey-in-process-powershell": {
      "reason": "Chocolatey 2.6.0 fails with ReflectionTypeLoadException even with the complete legacy Windows PowerShell assembly set"
    },
    "consumer-built-wmf-runtime": {
      "reason": "duplicates CFW-specific servicing, CLR, GAC, registry, and wrapper knowledge in every consumer build"
    }
  }
}
